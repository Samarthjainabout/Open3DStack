# OpenLane import settings for the 3D_TFT macro blocks.
# Set TFT3D_REPO to this repository root before sourcing from another design.

if { ![info exist ::env(TFT3D_REPO)] } {
    set ::env(TFT3D_REPO) [file normalize "$::env(DESIGN_DIR)/../.."]
}
if { ![info exist ::env(PDK_ROOT)] } {
    set ::env(PDK_ROOT) "$::env(TFT3D_REPO)/pdk"
}
if { ![info exist ::env(PDK)] } {
    set ::env(PDK) tft3d_platform
}

set tft3d_macro_lib "$::env(PDK_ROOT)/$::env(PDK)/libs.ref/tft3d_macros"

set ::env(VERILOG_FILES_BLACKBOX) [list \
    "$tft3d_macro_lib/verilog/3d_tft_blackboxes.v" \
]

set ::env(EXTRA_LEFS) [glob "$tft3d_macro_lib/lef/*.lef"]
set ::env(EXTRA_GDS_FILES) [glob "$tft3d_macro_lib/gds/*.gds"]

set ::env(EXTRA_LIBS) [list \
    "$tft3d_macro_lib/lib/3d_tft_placeholders.lib" \
]

set ::env(EXTRA_SPICE_FILES) [list \
    "$tft3d_macro_lib/spice/3d_tft_macros.spice" \
]

# OpenLane import settings for the 3D_TFT macro blocks.
# Set TFT3D_REPO to this repository root before sourcing from another design.

if { ![info exist ::env(TFT3D_REPO)] } {
    set ::env(TFT3D_REPO) [file normalize "$::env(DESIGN_DIR)/../.."]
}

set ::env(VERILOG_FILES_BLACKBOX) [list \
    "$::env(TFT3D_REPO)/openlane_import/src/3d_tft_blackboxes.v" \
]

set ::env(EXTRA_LEFS) [list \
    "$::env(TFT3D_REPO)/openlane_import/lef_platform/nfet_W20p825_L5.lef" \
    "$::env(TFT3D_REPO)/openlane_import/lef_platform/nfet_W24u_L5.lef" \
    "$::env(TFT3D_REPO)/openlane_import/lef_platform/nfet_W6u_L5.lef" \
    "$::env(TFT3D_REPO)/openlane_import/lef_platform/INV_X4PC_T5_nmos.lef" \
    "$::env(TFT3D_REPO)/openlane_import/lef_platform/wl_inv.lef" \
    "$::env(TFT3D_REPO)/openlane_import/lef_platform/wl_prebuffer.lef" \
    "$::env(TFT3D_REPO)/openlane_import/lef_platform/wl_sel.lef" \
]

set ::env(EXTRA_GDS_FILES) [list \
    "$::env(TFT3D_REPO)/openlane_import/gds_platform/nfet_W20p825_L5.gds" \
    "$::env(TFT3D_REPO)/openlane_import/gds_platform/nfet_W24u_L5.gds" \
    "$::env(TFT3D_REPO)/openlane_import/gds_platform/nfet_W6u_L5.gds" \
    "$::env(TFT3D_REPO)/openlane_import/gds_platform/INV_X4PC_T5_nmos.gds" \
    "$::env(TFT3D_REPO)/openlane_import/gds_platform/wl_inv.gds" \
    "$::env(TFT3D_REPO)/openlane_import/gds_platform/wl_prebuffer.gds" \
    "$::env(TFT3D_REPO)/openlane_import/gds_platform/wl_sel.gds" \
]

set ::env(EXTRA_LIBS) [list \
    "$::env(TFT3D_REPO)/openlane_import/lib/3d_tft_placeholders.lib" \
]

set ::env(EXTRA_SPICE_FILES) [list \
    "$::env(TFT3D_REPO)/openlane_import/spice/3d_tft_macros.spice" \
]
